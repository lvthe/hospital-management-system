# Backend Environment Variables
# Copy file này thành .env và điền các giá trị thực

# ==========================================
# Server Configuration
# ==========================================
NODE_ENV=development
PORT=3001
API_VERSION=v1

# ==========================================
# Database Configuration (PostgreSQL)
# ==========================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hospital_db
DB_USER=hospital_user
DB_PASSWORD=secure_password_here_change_me
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=2000

# ==========================================
# Redis Configuration (Caching & Sessions)
# ==========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ==========================================
# JWT Configuration (Authentication)
# ==========================================
# Change these to strong, random values in production!
JWT_SECRET=your_super_secret_jwt_key_must_be_strong_change_this_in_production
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d
JWT_ISSUER=hospital-system
JWT_AUDIENCE=web-app

# ==========================================
# Email Configuration (SendGrid or SMTP)
# ==========================================
# Option 1: Using SendGrid
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=SG.your_sendgrid_api_key_here
MAIL_FROM=noreply@hospital-system.com
MAIL_FROM_NAME=Hospital Management System

# Option 2: Using Gmail
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your_gmail_app_password
# MAIL_FROM=your-email@gmail.com

# Option 3: Using custom SMTP
# SMTP_HOST=your-mail-server.com
# SMTP_PORT=587
# SMTP_USER=your_username
# SMTP_PASSWORD=your_password
# SMTP_TLS=true

# ==========================================
# File Upload Configuration
# ==========================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf,doc,docx,xls,xlsx

# ==========================================
# Logging Configuration
# ==========================================
LOG_LEVEL=info
LOG_FORMAT=json
LOG_DIR=./logs

# ==========================================
# CORS Configuration
# ==========================================
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization

# ==========================================
# Rate Limiting
# ==========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_LOGIN_ATTEMPTS=5
RATE_LIMIT_LOGIN_WINDOW=900000

# ==========================================
# Encryption Configuration
# ==========================================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be exactly 32 bytes (64 hex characters)
ENCRYPT_KEY=your_32_byte_encryption_key_must_be_exactly_32_bytes_long_12345678

# ==========================================
# Third-Party Services
# ==========================================

# Stripe (Payment Processing)
STRIPE_PUBLIC_KEY=pk_test_your_public_key_here
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Twilio (SMS/Call Services)
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1_your_twilio_number

# Google OAuth (Optional - for SSO)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# AWS S3 (Optional - for file storage in production)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=hospital-system-bucket

# ==========================================
# Application Settings
# ==========================================

# Hospital/System Information
HOSPITAL_NAME=Central Hospital
HOSPITAL_PHONE=+84-28-1234-5678
HOSPITAL_EMAIL=info@hospital.com
HOSPITAL_ADDRESS=123 Medical Street, City

# Business Hours
BUSINESS_HOURS_START=08:00
BUSINESS_HOURS_END=18:00
BUSINESS_HOLIDAYS=2026-01-01,2026-12-25

# Appointment Settings
MAX_APPOINTMENT_DURATION=30
APPOINTMENT_REMINDER_TIME=24
MIN_ADVANCE_BOOKING_DAYS=1
MAX_ADVANCE_BOOKING_DAYS=30

# System Defaults
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=100
SESSION_TIMEOUT=1800
SESSION_CHECK_INTERVAL=300

# ==========================================
# Security Settings
# ==========================================
REQUIRE_EMAIL_VERIFICATION=true
REQUIRE_PHONE_VERIFICATION=false
ENABLE_TWO_FACTOR_AUTH=false
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL_CHARS=true

# ==========================================
# Monitoring & Analytics
# ==========================================

# Sentry (Error Tracking)
SENTRY_DNS=https://your_sentry_key@sentry.io/your_project_id

# New Relic (APM)
NEW_RELIC_LICENSE_KEY=your_new_relic_license_key
NEW_RELIC_APP_NAME=hospital-management-system

# DataDog (Monitoring)
DATADOG_API_KEY=your_datadog_api_key

# ==========================================
# Development Only Settings
# ==========================================
DEBUG=hospital-system:*
SEED_DATABASE=false
SKIP_MIGRATION=false
MOCK_EXTERNAL_SERVICES=false

# ==========================================
# Comments for Production Deployment
# ==========================================
# 1. Change NODE_ENV to 'production'
# 2. Use strong, randomly generated passwords
# 3. Use environment variables on your deployment platform (Heroku, AWS, etc)
# 4. Never commit the .env file to version control
# 5. Rotate JWT_SECRET regularly
# 6. Use HTTPS only
# 7. Enable CORS only for your domain
# 8. Set REQUIRE_EMAIL_VERIFICATION to true
# 9. Enable rate limiting
# 10. Configure monitoring & error tracking
