# Frontend Environment Variables
# Copy file này thành .env và điền các giá trị thực

# ==========================================
# API Configuration
# ==========================================
# Development
REACT_APP_API_URL=http://localhost:3001/api/v1

# Production
# REACT_APP_API_URL=https://api.hospital-system.com/api/v1

# API Settings
REACT_APP_API_TIMEOUT=30000

# ==========================================
# Application Configuration
# ==========================================
REACT_APP_ENV=development
REACT_APP_VERSION=1.0.0
REACT_APP_APP_NAME=Hospital Management System

# ==========================================
# Feature Flags
# ==========================================
REACT_APP_ENABLE_SMS=true
REACT_APP_ENABLE_VIDEO_CALL=false
REACT_APP_ENABLE_CHAT=false
REACT_APP_ENABLE_EMAIL_REMINDERS=true
REACT_APP_ENABLE_TWO_FACTOR_AUTH=false

# ==========================================
# Google Analytics (Optional)
# ==========================================
REACT_APP_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# ==========================================
# Sentry (Error Tracking - Optional)
# ==========================================
REACT_APP_SENTRY_DSN=https://your_sentry_key@sentry.io/your_project_id
REACT_APP_SENTRY_ENVIRONMENT=development

# ==========================================
# Authentication Configuration
# ==========================================
REACT_APP_TOKEN_STORAGE=sessionStorage
REACT_APP_SESSION_TIMEOUT=1800000

# ==========================================
# Third-Party Services
# ==========================================

# Google Maps (For location/directions)
REACT_APP_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Stripe (For payment processing)
REACT_APP_STRIPE_PUBLIC_KEY=pk_test_your_public_key_here

# Twilio (For video calls)
# REACT_APP_TWILIO_ACCOUNT_SID=your_account_sid
# REACT_APP_TWILIO_AUTH_TOKEN=your_auth_token

# ==========================================
# UI/UX Configuration
# ==========================================
REACT_APP_ITEMS_PER_PAGE=10
REACT_APP_THEME=light
REACT_APP_LANGUAGE=en

# ==========================================
# Development Settings
# ==========================================
# Set to true in development to see API logs
REACT_APP_DEBUG_MODE=false

# Enable Redux DevTools
REACT_APP_ENABLE_REDUX_DEVTOOLS=false

# ==========================================
# Production Build Settings
# ==========================================
# Generate inline source maps (smaller builds)
GENERATE_SOURCEMAP=false

# ==========================================
# Comments for Production Deployment
# ==========================================
# 1. Change REACT_APP_ENV to 'production'
# 2. Update REACT_APP_API_URL to your production API URL
# 3. Add real API keys for third-party services
# 4. Enable SENTRY_DSN for error tracking
# 5. Set REACT_APP_DEBUG_MODE to false
# 6. Set GENERATE_SOURCEMAP to false (smaller build)
# 7. Add Google Analytics ID
# 8. Test thoroughly before deploying
